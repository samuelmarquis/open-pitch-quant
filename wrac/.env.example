# Copy this file to .env for local machine paths used by cargo xtask.
# .env is intentionally ignored by git.

# AAX SDK root directory extracted from Avid's SDK archive.
AAX_SDK_ROOT=/absolute/path/to/aax-sdk-2-9-0

# AAX Validator/DSH archive downloaded from Avid.
# xtask extracts this archive into target/tools when AAX validation runs.
AAX_VALIDATOR_DSH_ARCHIVE=/absolute/path/to/aax-validator-dsh-2024-6-0-138bab0d-mac-arm64.tar.gz

# Optional override for slow machines or CI.
# AAX_VALIDATOR_TIMEOUT_SECS=900
